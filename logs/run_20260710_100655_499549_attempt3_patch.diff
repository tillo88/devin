diff --git a/calculator_logic.py b/calculator_logic.py
--- a/calculator_logic.py
+++ b/calculator_logic.py
@@ -58,3 +58,51 @@
     def clear_entry(self):
         self.display_text = '0'
 
+class UnitCalculatorLogic:
+    def __init__(self):
+        import pint
+        self.ureg = pint.UnitRegistry()
+        self.current_value = None
+        self.operation = None
+        self.memory = None
+
+    def set_quantity(self, value: str):
+        try:
+            self.current_value = self.ureg.Quantity(value)
+            return True
+        except pint.DimensionalityError:
+            return False
+
+    def set_operation(self, op: str):
+        if self.current_value is not None:
+            self.operation = op
+            self.memory = self.current_value
+            self.current_value = None
+
+    def calculate(self):
+        if self.operation is not None and self.current_value is not None:
+            try:
+                if self.memory.dimensionality != self.current_value.dimensionality:
+                    return 'Error: Incompatible units'
+                current = self.current_value.to_base_units()
+                memory = self.memory.to_base_units()
+                if self.operation == '+':
+                    result = memory + current
+                elif self.operation == '-':
+                    result = memory - current
+                elif self.operation == '*':
+                    result = memory * current
+                elif self.operation == '/':
+                    if current.magnitude != 0:
+                        result = memory / current
+                    else:
+                        return 'Error'
+                return result.to_string()
+            except Exception as e:
+                return 'Error'
+        return None
+
+    def clear(self):
+        self.current_value = None
+        self.operation = None
+        self.memory = None
