         self.current_value = 0
         self.display_text = '0'
         self.operation = None
@@ -6,6 +9,10 @@
         self.memory = None
 
+    def set_unit(self, unit: str):
+        self.current_unit = unit
+
+    def get_unit(self):
+        return self.current_unit
+
     def add_digit(self, digit: int):
         if self.display_text == 'Error':
             self.display_text = '0'
@@ -21,12 +28,22 @@
             self.memory = float(self.display_text)
             self.display_text = '0'
 
+    def add_digit_with_unit(self, digit: int):
+        if self.display_text == 'Error':
+            self.display_text = '0'
+        if self.display_text == '0':
+            self.display_text = str(digit)
+        else:
+            self.display_text += str(digit)
+
     def calculate(self):
         if self.operation is not None:
             current = float(self.display_text)
+            if self.current_unit is not None and self.memory is not None:
+                q_mem = self.ureg.Quantity(self.memory, self.current_unit)
+                q_cur = self.ureg.Quantity(current, self.current_unit)
+                result = q_mem + self.ureg.Quantity(self.operation, self.current_unit) * q_cur
+                self.current_value = result.magnitude
+                self.display_text = str(result.magnitude)
+                self.current_unit = result.units
+            else:
+                if self.operation == '+':
+                    result = self.memory + current
+                elif self.operation == '-':
+                    result = self.memory - current
+                elif self.operation == '*':
+                    result = self.memory * current
+                elif self.operation == '/':
+                    if current != 0:
+                        result = self.memory / current
+                    else:
+                        result = 'Error'
+                self.current_value = result
+                self.display_text = str(result)
+                self.operation = None
+                self.memory = None
+                return result
+        return None
+
+    def convert_unit(self, new_unit: str):
+        if self.current_unit is not None:
+            quantity = self.ureg.Quantity(self.current_value, self.current_unit)
+            converted = quantity.to(new_unit)
+            self.current_value = converted.magnitude
+            self.display_text = str(converted.magnitude)
+            self.current_unit = new_unit
+
     def clear(self):
         self.current_value = 0
         self.display_text = '0'
         self.operation = None
         self.memory = None
+        self.current_unit = None
 
